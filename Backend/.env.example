# ── Google Cloud ───────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# ── BigQuery ───────────────────────────────────────────────────────────────────
BQ_DATASET=ai_news
BQ_LABELED_TABLE=labeled_articles
BQ_SUMMARY_TABLE=summarized_articles
BQ_HITL_TABLE=hitl_reviews

# ── Vertex AI Endpoint ─────────────────────────────────────────────────────────
# Lấy Endpoint ID từ: GCP Console → Vertex AI → Online prediction → Endpoints
# Chỉ cần phần số, ví dụ: 1234567890123456789
VERTEX_ENDPOINT_ID=your-vertex-endpoint-id

# ── Flask ──────────────────────────────────────────────────────────────────────
PORT=8080
FLASK_DEBUG=false

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL=300

# ── Authentication (nếu không dùng ADC / Workload Identity) ───────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
