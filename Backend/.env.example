# ── Google Cloud / BigQuery ────────────────────────────────────────────────────
# GCP Project ID (thay bằng project ID thực của bạn)
GCP_PROJECT=your-gcp-project-id

# BigQuery dataset và tên các bảng
BQ_DATASET=ai_news
BQ_LABELED_TABLE=labeled_articles
BQ_SUMMARY_TABLE=summarized_articles

# Đường dẫn tới Service Account key (nếu không dùng ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── ML Model ──────────────────────────────────────────────────────────────────
TFIDF_PATH=../src/ML/Training/tfidf_vectorizer.pkl
MODEL_PATH=../src/ML/Training/LinearSVC.pkl

# ── Flask ─────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=true

# Thời gian cache stats/labels (giây)
CACHE_TTL=300
